NODE_ENV=development
PORT=5000
MONGO_URI=mongodb+srv://<user>:<password>@cluster.mongodb.net/interviewai
# Use at least 32 characters in all environments.
JWT_SECRET=replace-with-a-long-random-secret-value-32-characters-min
JWT_REFRESH_SECRET=replace-with-a-different-long-random-refresh-secret
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=14d
OPENROUTER_API_KEY=or-xxxxxxxxxxxxxxxxxxxx
OPENROUTER_MODEL=meta-llama/llama-3.3-70b-instruct:free
OPENROUTER_MODEL_FALLBACKS=meta-llama/llama-3.1-8b-instruct:free,mistralai/mistral-7b-instruct:free
OPENROUTER_QUESTION_FALLBACK_MODELS=
OPENROUTER_FEEDBACK_FALLBACK_MODELS=
AI_CIRCUIT_BREAKER_FAILURE_THRESHOLD=5
AI_CIRCUIT_BREAKER_COOLDOWN_MS=20000
AI_ERROR_BUDGET_WINDOW_MS=60000
AI_ERROR_BUDGET_MAX_FAILURE_RATE=0.35
GOOGLE_CLIENT_ID=your-google-web-client-id.apps.googleusercontent.com
# Must be https in production.
FRONTEND_URL=http://localhost:5173
CORS_ORIGINS=http://localhost:5173
MAX_RESUME_FILE_SIZE_BYTES=2097152
# Optional but recommended for distributed production rate limiting.
REDIS_REST_URL=https://<upstash-endpoint>.upstash.io
REDIS_REST_TOKEN=<upstash-rest-token>
REDIS_KEY_PREFIX=ip
REDIS_MEMORY_POLICY=allkeys-lfu
REDIS_PERSISTENCE_MODE=cache-only
METRICS_API_KEY=replace-with-metrics-read-key
