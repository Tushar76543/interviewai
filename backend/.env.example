NODE_ENV=development
PORT=5000
MONGO_URI=mongodb+srv://<user>:<password>@cluster.mongodb.net/interviewai
# Use at least 32 characters in all environments.
JWT_SECRET=replace-with-a-long-random-secret-value-32-characters-min
OPENROUTER_API_KEY=or-xxxxxxxxxxxxxxxxxxxx
OPENROUTER_MODEL=meta-llama/llama-3.3-70b-instruct:free
# Must be https in production.
FRONTEND_URL=http://localhost:5173
CORS_ORIGINS=http://localhost:5173
MAX_RESUME_FILE_SIZE_BYTES=2097152
# Optional but recommended for distributed production rate limiting.
REDIS_REST_URL=https://<upstash-endpoint>.upstash.io
REDIS_REST_TOKEN=<upstash-rest-token>
