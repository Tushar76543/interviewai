# Frontend Environment Variables (Vercel)
# This file should be used as reference only
# Set these in Vercel Dashboard under Project Settings > Environment Variables

# For local development, create .env.local:
# You can set either a full API base (.../api) or only origin.
VITE_API_URL=http://localhost:5000/api

# Google OAuth client ID for Google Sign-In.
# Primary variable name:
VITE_GOOGLE_CLIENT_ID=your-google-web-client-id.apps.googleusercontent.com
# Backward-compatible legacy name (optional):
# VITE_GOOGLE_OAUTH_CLIENT_ID=your-google-web-client-id.apps.googleusercontent.com

# For Vercel production:
# Set VITE_API_URL to your backend URL:
# - If backend is on Render: https://your-backend.onrender.com/api
# - If using same Vercel project for API functions: /api
